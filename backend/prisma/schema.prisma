//backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ======================
// SESSION
// ======================

model Session {
  id String @id @default(uuid())

  userId String

  task String

  allowedSites String[]

  startTime DateTime @default(now())

  endTime DateTime?

  // ======================
  // METRICS
  // ======================

  focusTime Float?

  idleTime Float?

  interruptions Int?

  distractions Int?

  score Int?

  // ======================
  // ATTENTION METRICS
  // ======================

  attentiveTime Float?

  distractedTime Float?

  phoneTime Float?

  absentTime Float?

  attentionScore Float?

  // ======================
  // AI
  // ======================

  feedback String?

  createdAt DateTime @default(now())

  // ======================
  // RELATIONS
  // ======================

  events Event[]

  domains SessionDomain[]

  attentionSegments AttentionSegment[]
}

// ======================
// EVENT
// ======================

model Event {
  id String @id @default(uuid())

  sessionId String

  type EventType

  value String?

  timestamp Float

  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ======================
// ATTENTION SEGMENT
// ======================

model AttentionSegment {
  id String @id @default(uuid())

  sessionId String

  state AttentionState

  startedAt DateTime

  endedAt DateTime

  // milliseconds
  duration Int

  confidence Float?

  createdAt DateTime @default(now())

  // ======================
  // RELATION
  // ======================

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])

  @@index([state])

  @@index([startedAt])
}

// ======================
// SESSION DOMAIN
// ======================

model SessionDomain {
  id String @id @default(uuid())

  sessionId String

  domain String

  // seconds
  time Float

  // ======================
  // CLASSIFICATION
  // ======================

  category String

  relevant Boolean

  isDistraction Boolean

  // ======================
  // AI
  // ======================

  aiConfidence Float?

  aiReason String?

  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ======================
// EVENT TYPE
// ======================

enum EventType {
  ACTIVE

  IDLE

  TAB_CHANGE
}

// ======================
// ATTENTION STATE
// ======================

enum AttentionState {
  ATTENTIVE

  DISTRACTED

  PHONE

  ABSENT
}