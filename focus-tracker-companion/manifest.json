{
  "manifest_version": 3,

  "name": "Focus Tracker Extension",

  "version": "1.0",

  "permissions": ["tabs", "activeTab", "scripting"],

  "host_permissions": [
    "<all_urls>",
    "https://focus-tracker-system-production.up.railway.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],

      "js": ["content.js"],

      "run_at": "document_start"
    }
  ]
}
